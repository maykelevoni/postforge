# Database
DATABASE_URL="postgresql://user:password@localhost:5432/postforge"

# Auth
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://getpostforge.cloud"

# Optional: Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Note: API keys (OpenRouter, fal.ai, NewsAPI) are stored
# in the database Setting table, not in environment variables.
# Brevo credentials (brevo_api_key, brevo_from_email) are also stored
# in the database Setting table via the app Settings page.
