# Database
DATABASE_URL="postgresql://user:password@localhost:5432/postforge"

# Auth
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Note: API keys (OpenRouter, fal.ai, post-bridge, NewsAPI) are stored
# in the database Setting table, not in environment variables.
# Resend credentials (resend_api_key, resend_from_email) are also stored
# in the database Setting table, not in environment variables.

# Optional fallback: set RESEND_API_KEY here only if you need it at the server level.
# Normally, users set this in the app Settings page (stored in DB).
# RESEND_API_KEY=""
